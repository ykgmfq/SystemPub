#!/usr/bin/make -f

export CGO_ENABLED = 0
export GOFLAGS = -mod=vendor
export GOPROXY = off
export GOTOOLCHAIN = local

%:
	dh $@

override_dh_auto_build:
	go build -ldflags "-s -w" -o systempub .

override_dh_auto_test:
	go test ./...

# The service needs /etc/mqtt_pw.txt before it can run,
# so do not enable or start it on installation. This matches
# the behaviour of the RPM package.
override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start

# The binary is built static and already stripped by the linker flags.
override_dh_strip override_dh_dwz:
